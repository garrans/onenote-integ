# .env.example — copy to .env for local development
# Never commit .env to source control.

# --- App ---
APP_LOG_LEVEL=DEBUG
APP_ENVIRONMENT=development

# --- Auth (service account delegated) ---
AUTH_TENANT_ID=<your-azure-ad-tenant-id>
AUTH_CLIENT_ID=<your-app-registration-client-id>
# Must be a Key Vault reference: keyvault://<vault-name>/<secret-name>
AUTH_CLIENT_SECRET_REF=keyvault://<vault-name>/client-secret
AUTH_REFRESH_TOKEN_REF=keyvault://<vault-name>/refresh-token

# --- Event Bus (Azure Service Bus) ---
EVENTBUS_CONNECTION_STRING_REF=keyvault://<vault-name>/sb-connection-string
EVENTBUS_NAMESPACE=<your-namespace>.servicebus.windows.net

# --- State Store ---
STATESTORE_CONNECTION_STRING_REF=keyvault://<vault-name>/db-connection-string
STATESTORE_DATABASE_NAME=onenote_integ
